# ── Discord ───────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications -> your app -> Bot
BOT_TOKEN=

# The Discord server (guild) ID this bot serves.
GUILD_ID=

# Role ID allowed to click Accept / Deny / Revoke on applications.
ADMIN_ROLE_ID=

# Role ID auto-assigned when an application is accepted. Leave empty to skip role assignment.
WHITELISTED_ROLE_ID=

# Channel where the public "Apply" panel is posted.
PUBLIC_CHANNEL_ID=

# Channel where new applications are posted for admin review.
ADMIN_CHANNEL_ID=

# ── Database ──────────────────────────────────────────────────────────────
# SQLite — a single embedded file, no separate database server needed.
# Leave blank to default to ./data/wl.sqlite3 (created automatically).
DB_PATH=

# ── Whitelist config ──────────────────────────────────────────────────────
MAX_SLOTS=40

# ── Optional webhook notifications (leave blank to disable) ─────────────
# Plain fire-and-forget alerts, separate from the interactive admin embed.
# Create these under a channel's Integrations -> Webhooks -> New Webhook.
# WEBHOOK_APPLY_URL fires when a new application is submitted.
# WEBHOOK_ACCEPT_URL fires when an application is accepted.
WEBHOOK_APPLY_URL=
WEBHOOK_ACCEPT_URL=
